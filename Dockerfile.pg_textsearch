FROM postgres:18

ARG PG_TEXTSEARCH_VERSION=v1.0.0

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      ca-certificates \
      git \
      build-essential \
      postgresql-server-dev-18 \
 && git clone --branch "${PG_TEXTSEARCH_VERSION}" --depth 1 https://github.com/timescale/pg_textsearch /tmp/pg_textsearch \
 && make -C /tmp/pg_textsearch \
 && make -C /tmp/pg_textsearch install \
 && rm -rf /tmp/pg_textsearch /var/lib/apt/lists/*
