{
  "name": "pginbox",
  "module": "src/server/index.ts",
  "type": "module",
  "scripts": {
    "auth:cleanup": "bun src/server/jobs/auth-cleanup.ts",
    "dev": "bun --watch src/server/index.ts",
    "start": "bun src/server/index.ts",
    "test": "bun test test",
    "codegen": "kysely-codegen --dialect postgres --url $DATABASE_URL --out-file src/server/types/db.d.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "latest",
    "elysia": "latest",
    "kysely": "latest",
    "nodemailer": "^8.0.2",
    "pg": "latest"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "latest",
    "kysely-codegen": "latest",
    "typescript": "latest"
  }
}
